# Archivo de ejemplo para variables de entorno
# Copia este archivo como .env y configura tus valores reales
# IMPORTANTE: Agrega .env a .gitignore para no commitear credenciales

# Configuración de SQL Server en la nube
SQL_SERVER_HOST=hecferme-sqlserver.database.windows.net
SQL_SERVER_DATABASE=hecferme-sql-server
SQL_SERVER_USER=user01
SQL_SERVER_PASSWORD=Tu_Password_Seguro_Aqui

# Configuración opcional de Azure Key Vault
AZURE_KEY_VAULT_URI=https://tu-key-vault.vault.azure.net/
AZURE_CLIENT_ID=tu-client-id
AZURE_CLIENT_SECRET=tu-client-secret
AZURE_TENANT_ID=tu-tenant-id